# macOS
.DS_Store
.AppleDouble
.LSOverride
**/.DS_Store

# Secrets and sensitive files
.env
.env.local
*.key
*.pem
*_rsa
*_dsa
*_ed25519
*_ecdsa

# Local configuration files (machine-specific, not committed)
zsh/.zshrc.local
git/.gitconfig.local
.claude/settings.local.json

# Backup directories created by install script
.dotfiles_backup_*/

# Vim swap files
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
